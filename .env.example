# Backend (FastAPI) — copy to `.env` in repo root for `docker compose`.
# Never commit real secrets.

# Required
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
OPENAI_API_KEY=

# Optional (defaults shown where applicable)
OPENAI_MODEL=openai:gpt-5.4
# REDIS_URL defaults to redis://redis:6379/0 when using docker-compose.yml
REDIS_URL=redis://redis:6379/0

# Optional — tools & observability
LANGSMITH_TRACING=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=

TAVILY_API_KEY=
ALPHA_VANTAGE_API_KEY=
SEC_USER_AGENT=FinAgent contact@example.com
